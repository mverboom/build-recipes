[INFO]
arch=amd64
excludefromall=1

[VERSION]
B_GITVER -i "^22" https://github.com/nodejs/node/

[REQUIRED]
python3 make gcc g++ python3-distutils

[REQUIRED DEBIAN TRIXIE]
python3 make gcc g++

[BUILD]
B_GET git https://github.com/nodejs/node/ nodejs
cd nodejs
git checkout v$B_VERSION
test "$B_ARCH" = "armhf" && export CXXFLAGS="-march=armv6k -mfpu=vfpv2"
./configure --prefix=/opt/nodejs
make -j 2
make install DESTDIR=$B_INSTALLDIR
B_LINKFILES /opt/nodejs/bin /usr/bin

[PKG]
type=deb
torepo=y

[DEB]
Package: nodejs-22
Version: B_VERSION
Section: nodejs-lts
Priority: optional
Architecture: B_ARCH
Maintainer: B_MAIL
Description: Nodejs 22 custom B_ORG build
Provides: nodejs-runtime
Conflicts: nodejs, nodejs-runtime
