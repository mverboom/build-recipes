[INFO]
arch=amd64

[VERSION]
B_GITVER https://gitlab.com/wireshark/wireshark.git/

[REQUIRED DEBIAN]
cmake make gcc g++ flex bison libglib2.0-dev qt6-base-dev qt6-base-dev-tools qt6-tools-dev qt6-tools-dev-tools qt6-svg-dev qt6-multimedia-dev qt6-5compat-dev libc-ares-dev libpcap-dev python3 perl libgcrypt20-dev libnl-3-dev libnl-route-3-dev libnl-genl-3-dev libkrb5-dev libsmi2-dev asciidoctor libsbc-dev liblua5.4-dev libnl-cli-3-dev libparse-yapp-perl libcap-dev liblz4-dev libsnappy-dev libzstd-dev libspandsp-dev libxml2-dev libminizip-dev git ninja-build xsltproc libspeexdsp-dev libgnutls28-dev libnghttp2-dev libnghttp3-dev libssh2-1-dev libsystemd-dev libbcg729-dev libopencore-amrnb-dev libopus-dev

[BUILD]
B_GET git https://gitlab.com/wireshark/wireshark/ wireshark
cd wireshark
git checkout v${B_VERSION}
mkdir build
cd build
cmake -DCMAKE_INSTALL_PREFIX:PATH=/opt/wireshark ..
make -j $(nproc)
#make -j $(nproc) all_guides
make install DESTDIR=$B_INSTALLDIR
B_LINKFILES /opt/wireshark/bin /usr/bin
#B_LINKFILES /opt/wireshark/share/man/man1 /usr/share/man/man1
#B_LINKFILES /opt/wireshark/share/man/man4 /usr/share/man/man4

[PKG]
type=deb
torepo=y

[DEB]
Package: wireshark
Version: B_VERSION
Section: wireshark
Priority: optional
Architecture: B_ARCH
Maintainer: B_MAIL
Description: wireshark custom B_ORG build
Depends: libc6, libgcc-s1, libglib2.0-0t64, libnl-3-200, libnl-genl-3-200, libnl-route-3-200, libpcap0.8t64, libqt6core6t64, libqt6gui6, libqt6widgets6, libqt6printsupport6, libqt6concurrent6, libqt6core5compat6, libqt6multimedia6, libqt6svg6, libqt6network6, libqt6dbus6, libstdc++6, zlib1g, libsmi2t64, libnghttp3-9, libbcg729-0
