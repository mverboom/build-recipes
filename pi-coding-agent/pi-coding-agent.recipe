[INFO]
arch=amd64

[VERSION]
B_GITVER https://github.com/badlogic/pi-mono/

[REQUIRED]
nodejs-22-B_PF

[BUILD]
export npm_config_prefix=$B_INSTALLDIR/opt/pi-coding-agent
npm install @earendil-works/pi-coding-agent@$B_VERSION --prefix $B_INSTALLDIR/opt/pi-coding-agent
B_LINKFILE /opt/pi-coding-agent/node_modules/.bin/pi /usr/bin
ln -s /usr/bin/fdfind $B_INSTALLDIR/usr/bin/fd

[PKG]
type=deb
torepo=y

[DEB]
Package: pi-coding-agent
Version: B_VERSION
Section: pi-mono
Priority: optional
Architecture: B_ARCH
Maintainer: B_MAIL
Description: pi-coding-agent custom B_ORG build
Homepage: https://pi.dev/
Depends: nodejs-22-B_PF,ripgrep,fd-find
