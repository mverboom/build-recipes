[INFO]
arch=amd64

[VERSION]
B_GITVER -e citest https://github.com/ollama/ollama/

[REQUIRED]
golang-B_PF gcc g++ make cmake
#golang-B_PF gcc g++ make cmake nvidia-cuda-toolkit-gcc

[BUILD]
export GOROOT=/opt/go
export PATH=/opt/go/bin:$PATH
B_GET git https://github.com/ollama/ollama/ ollama
cd ollama
git checkout v$B_VERSION

# Build the native payload (llama-server, shared libs, CPU backends) via cmake superbuild
# Also builds the Go binary with embedded version info
cmake -DCMAKE_INSTALL_PREFIX=$B_INSTALLDIR/opt/ollama -DOLLAMA_VERSION=$B_VERSION --preset 'Default'
cmake --build --parallel $(nproc) --preset 'Default'

# Install the Go binary and all native payloads
# The component name is ollama-local per cmake/local.cmake
cmake --install build --component ollama-local

B_LINKFILE /opt/ollama/bin/ollama /usr/bin

[PKG]
type=deb
torepo=y

[DEB]
Package: ollama
Version: B_VERSION
Section: ollama
Priority: optional
Architecture: B_ARCH
Depends: libc6 (>= 2.36), libstdc++6 (>= 12), libgcc-s1
Maintainer: B_MAIL
Homepage: https://ollama.com/
Description: ollama B_PF custom build
