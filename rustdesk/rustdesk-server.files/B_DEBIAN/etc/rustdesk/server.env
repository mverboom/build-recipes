# RustDesk Server Environment Configuration
# See: https://rustdesk.com/docs/en/self-host/rustdesk-server-oss/
#
# After first start, a key pair is auto-generated in /var/lib/rustdesk/.
# The public key must be provided to clients in the "Key" field.
#
# KEY variables are read from environment by both hbbs and hbbr.
# For hbbs-specific options, also edit /etc/rustdesk/server.ini

# Public key for client authentication.
# Uncomment and set this to restrict access to clients with matching key.
# KEY=

# Base port for hbbs (hbbs default: 21115, hbbr default: 21117)
# PORT=21115

# Database URL (relative to WorkingDirectory /var/lib/rustdesk)
DATABASE_URL=sqlite://./db_v2.sqlite3

# Maximum database connections (default: 1)
# MAX_DATABASE_CONNECTIONS=1