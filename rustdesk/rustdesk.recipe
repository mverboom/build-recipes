[INFO]
arch=amd64

[VERSION]
B_GITVER https://github.com/rustdesk/rustdesk.git

[REQUIRED]
curl

[BUILD]
B_GET http https://github.com/rustdesk/rustdesk/releases/download/$B_VERSION/rustdesk-$B_VERSION-x86_64.deb rustdesk-$B_VERSION-x86_64.deb

# Extract the upstream deb
dpkg-deb -x rustdesk-$B_VERSION-x86_64.deb upstream

# Install main binary and bundled libraries to /opt/rustdesk
mkdir -p $B_INSTALLDIR/opt/rustdesk/lib $B_INSTALLDIR/opt/rustdesk/data
cp upstream/usr/share/rustdesk/rustdesk $B_INSTALLDIR/opt/rustdesk/
cp -r upstream/usr/share/rustdesk/lib/* $B_INSTALLDIR/opt/rustdesk/lib/
cp -r upstream/usr/share/rustdesk/data/* $B_INSTALLDIR/opt/rustdesk/data/

# Symlink binary to /usr/bin
mkdir -p $B_INSTALLDIR/usr/bin
ln -s /opt/rustdesk/rustdesk $B_INSTALLDIR/usr/bin/rustdesk

# Desktop files
mkdir -p $B_INSTALLDIR/usr/share/applications
cp upstream/usr/share/applications/rustdesk.desktop $B_INSTALLDIR/usr/share/applications/
cp upstream/usr/share/applications/rustdesk-link.desktop $B_INSTALLDIR/usr/share/applications/

# Icons
mkdir -p $B_INSTALLDIR/usr/share/icons/hicolor/256x256/apps
mkdir -p $B_INSTALLDIR/usr/share/icons/hicolor/scalable/apps
cp upstream/usr/share/icons/hicolor/256x256/apps/rustdesk.png $B_INSTALLDIR/usr/share/icons/hicolor/256x256/apps/
cp upstream/usr/share/icons/hicolor/scalable/apps/rustdesk.svg $B_INSTALLDIR/usr/share/icons/hicolor/scalable/apps/

# RustDesk config directory
mkdir -p $B_INSTALLDIR/etc/rustdesk

# Cleanup upstream extraction
rm -rf upstream rustdesk-$B_VERSION-x86_64.deb

[PKG]
type=deb
torepo=y

[DEB]
Package: rustdesk
Version: B_VERSION
Section: net
Priority: optional
Architecture: B_ARCH
Maintainer: B_MAIL
Description: RustDesk remote desktop client - custom B_ORG build
Homepage: https://github.com/rustdesk/rustdesk
Depends: libgtk-3-0t64 | libgtk-3-0, libxcb-randr0, libxdo3 | libxdo4, libxfixes3, libxcb-shape0, libxcb-xfixes0, libasound2t64 | libasound2, curl, libva2, libva-drm2, libva-x11-2, libgstreamer-plugins-base1.0-0, gstreamer1.0-pipewire
Recommends: libayatana-appindicator3-1
