[INFO]
arch=amd64

[VERSION]
B_GITVER https://github.com/sassman/t-rec-rs

[REQUIRED]
rustc-B_PF libx11-dev imagemagick

[BUILD]
B_GET git https://github.com/sassman/t-rec-rs t-rec
cd t-rec
git checkout v${B_VERSION}
cargo build --release
mkdir -p $B_INSTALLDIR/usr/bin
cp target/release/t-rec $B_INSTALLDIR/usr/bin

[PKG]
type=deb
torepo=y

[DEB]
Package: t-rec
Version: B_VERSION
Section: t-rec
Priority: optional
Architecture: B_ARCH
Maintainer: B_MAIL
Description: t-rec server custom B_ORG build
Homepage: https://github.com/sassman/t-rec-rs
