[INFO]
arch=amd64

[VERSION]
B_GITHUBVER https://github.com/searxng/searxng

[REQUIRED]
python3-dev python3-babel python3-venv uwsgi uwsgi-plugin-python3 build-essential libxslt1-dev zlib1g-dev libffi-dev libssl-dev

[BUILD DEBIAN]
set -o pipefail
B_GET git https://github.com/searxng/searxng searxng
cd searxng
DEST=$B_INSTALLDIR/opt/searxng
python3 -m venv "$DEST"
. "$DEST/bin/activate"

# Pre-install build dependencies (required because setup.py imports them at module level)
pip3 install --no-cache -r requirements.txt
pip3 install -U pip setuptools wheel pyyaml msgspec typing-extensions pybind11

# NON-editable install -- this places searx/ into site-packages
pip3 install --no-build-isolation .

deactivate

# Rewrite hardcoded paths in bin scripts from build path to /opt/searxng
pushd "$DEST/bin"
shopt -s extglob
sed -i "s|$DEST|/opt/searxng|g" !(__pycache__)
popd

# Copy the settings file for configuration
mkdir -p "$B_INSTALLDIR/etc/searxng"
cp searx/settings.yml "$B_INSTALLDIR/etc/searxng/settings.yml.example"


[PKG]
type=deb
torepo=y

[DEB]
Package: searxng
Version: B_VERSION
Section: searxng
Priority: optional
Architecture: B_ARCH
Maintainer: B_MAIL
Description: Searxng custom B_ORG build
Homepage: https://github.com/searxng/searxng
Depends: redis,git
